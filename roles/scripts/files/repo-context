#!/usr/bin/env bash

set -euo pipefail

readonly CACHE_ROOT="${HOME}/.local/share/agent-sources"
readonly MANIFEST_PATH="${CACHE_ROOT}/manifest.json"

usage() {
	cat <<'EOF'
Usage:
  repo-context
  repo-context list
  repo-context resolve <query>
  repo-context <repo-or-url>[@branch:<name>|@tag:<selector>]

Examples:
  repo-context list
  repo-context resolve react
  repo-context Effect-TS/effect
  repo-context Effect-TS/effect@branch:main
  repo-context Effect-TS/effect@tag:v3
  repo-context https://github.com/Effect-TS/effect.git
  repo-context git@github.com:Effect-TS/effect.git@branch:main
EOF
}

fail() {
	echo "$*" >&2
	exit 1
}

require_dependencies() {
	local dependency

	for dependency in git jq; do
		if ! command -v "$dependency" >/dev/null 2>&1; then
			fail "missing dependency: $dependency"
		fi
	done
}

ensure_cache_root() {
	mkdir -p "$CACHE_ROOT"
}

ensure_manifest_exists() {
	ensure_cache_root

	if [[ ! -f "$MANIFEST_PATH" ]]; then
		printf '{\n  "version": 1,\n  "repositories": []\n}\n' >"$MANIFEST_PATH"
	fi
}

manifest_exists_with_repositories() {
	if [[ ! -f $MANIFEST_PATH ]]; then
		return 1
	fi

	[[ $(jq '.repositories | length' "$MANIFEST_PATH") -gt 0 ]]
}

write_manifest_json() {
	local json=$1
	local temp_file

	temp_file=$(mktemp "${MANIFEST_PATH}.XXXXXX")
	printf '%s\n' "$json" >"$temp_file"
	mv "$temp_file" "$MANIFEST_PATH"
}

manifest_upsert_repository() {
	local entry_json=$1
	local updated_json

	ensure_manifest_exists

	updated_json=$(jq --argjson entry "$entry_json" '
		.repositories |= (
			map(select(.path != $entry.path)) + [$entry]
			| sort_by(.path)
		)
	' "$MANIFEST_PATH")

	write_manifest_json "$updated_json"
}

matches_tag_selector() {
	local selector=$1
	local tag_name=$2

	if [[ $tag_name == "$selector" ]]; then
		return 0
	fi

	if [[ $tag_name == "$selector".* ]]; then
		return 0
	fi

	return 1
}

resolve_highest_matching_tag() {
	local selector=$1
	local repo_path=$2
	local matching_tags=()
	local tag_name

	while IFS= read -r tag_name; do
		[[ -z $tag_name ]] && continue

		if matches_tag_selector "$selector" "$tag_name"; then
			matching_tags+=("$tag_name")
		fi
	done < <(git -C "$repo_path" tag --list)

	if [[ ${#matching_tags[@]} -eq 0 ]]; then
		return 1
	fi

	printf '%s\n' "${matching_tags[@]}" | sort -V | tail -n 1
}

parse_ref_spec() {
	local input=$1
	local source_part=$input

	REF_MODE="default_branch"
	REF_VALUE=""

	if [[ $input =~ ^(.+)@(branch|tag):(.+)$ ]]; then
		source_part=${BASH_REMATCH[1]}
		REF_MODE=${BASH_REMATCH[2]}
		REF_VALUE=${BASH_REMATCH[3]}
	fi

	if [[ -z $source_part ]]; then
		fail "repository input cannot be empty"
	fi

	REPOSITORY_SOURCE=$source_part
}

parse_repository_source() {
	local source=$1
	local host=""
	local owner_path=""
	local repo_name=""
	local remote=""
	local path_part=""
	local normalized_local_path=""

	if [[ $source =~ ^([A-Za-z0-9._-]+)/([A-Za-z0-9._-]+)$ ]]; then
		host="github.com"
		owner_path=${BASH_REMATCH[1]}
		repo_name=${BASH_REMATCH[2]}
		remote="https://${host}/${owner_path}/${repo_name}.git"
	else
		remote=$source

		if [[ $source =~ ^file://(/.+)$ ]]; then
			host="local"
			path_part=${BASH_REMATCH[1]}
		elif [[ $source == /* || $source == ./* || $source == ../* ]]; then
			host="local"
			normalized_local_path=$(cd -- "$(dirname -- "$source")" && pwd)/$(basename -- "$source")
			remote=$normalized_local_path
			path_part=$normalized_local_path
		elif [[ $source =~ ^ssh://([^/]+)/(.+)$ ]]; then
			host=${BASH_REMATCH[1]}
			path_part=${BASH_REMATCH[2]}
		elif [[ $source =~ ^([A-Za-z][A-Za-z0-9+.-]*)://([^/]+)/(.+)$ ]]; then
			host=${BASH_REMATCH[2]}
			path_part=${BASH_REMATCH[3]}
		elif [[ $source =~ ^([^@]+@)?([^:]+):(.+)$ ]]; then
			host=${BASH_REMATCH[2]}
			path_part=${BASH_REMATCH[3]}
		else
			fail "unsupported repository source: $source"
		fi

		path_part=${path_part#/}
		path_part=${path_part%.git}

		if [[ $path_part != */* ]]; then
			fail "repository source must include owner and repo: $source"
		fi

		repo_name=${path_part##*/}
		owner_path=${path_part%/*}
	fi

	if [[ -z $host || -z $owner_path || -z $repo_name ]]; then
		fail "failed to normalize repository source: $source"
	fi

	REPO_HOST=$host
	REPO_OWNER=$owner_path
	REPO_NAME=$repo_name
	REPO_REMOTE=$remote
	REPO_PATH="${CACHE_ROOT}/${REPO_HOST}/${REPO_OWNER}/${REPO_NAME}"
}

build_repository_id() {
	local id="${REPO_HOST}/${REPO_OWNER}/${REPO_NAME}"

	case $REF_MODE in
		default_branch)
			printf '%s\n' "$id"
			;;
		branch|tag)
			printf '%s#%s:%s\n' "$id" "$REF_MODE" "$REF_VALUE"
			;;
		*)
			fail "unsupported ref mode: $REF_MODE"
			;;
	esac
}

build_manifest_entry() {
	local repo_id

	repo_id=$(build_repository_id)

	case $REF_MODE in
		default_branch)
			jq -n \
				--arg id "$repo_id" \
				--arg host "$REPO_HOST" \
				--arg owner "$REPO_OWNER" \
				--arg repo "$REPO_NAME" \
				--arg remote "$REPO_REMOTE" \
				--arg path "$REPO_PATH" \
				'{
					id: $id,
					host: $host,
					owner: $owner,
					repo: $repo,
					remote: $remote,
					path: $path,
					mode: "default_branch"
				}'
			;;
		branch)
			jq -n \
				--arg id "$repo_id" \
				--arg host "$REPO_HOST" \
				--arg owner "$REPO_OWNER" \
				--arg repo "$REPO_NAME" \
				--arg remote "$REPO_REMOTE" \
				--arg path "$REPO_PATH" \
				--arg branch "$REF_VALUE" \
				'{
					id: $id,
					host: $host,
					owner: $owner,
					repo: $repo,
					remote: $remote,
					path: $path,
					mode: "branch",
					branch: $branch
				}'
			;;
		tag)
			jq -n \
				--arg id "$repo_id" \
				--arg host "$REPO_HOST" \
				--arg owner "$REPO_OWNER" \
				--arg repo "$REPO_NAME" \
				--arg remote "$REPO_REMOTE" \
				--arg path "$REPO_PATH" \
				--arg selector "$REF_VALUE" \
				'{
					id: $id,
					host: $host,
					owner: $owner,
					repo: $repo,
					remote: $remote,
					path: $path,
					mode: "tag",
					tag_selector: $selector
				}'
			;;
		*)
			fail "unsupported ref mode: $REF_MODE"
			;;
	esac
}

ensure_local_repository() {
	local remote=$1
	local repo_path=$2

	if [[ -e $repo_path && ! -d $repo_path ]]; then
		fail "target path exists and is not a directory: $repo_path"
	fi

	if [[ -d $repo_path && ! -d $repo_path/.git ]]; then
		fail "target path exists but is not a git repository: $repo_path"
	fi

	if [[ ! -d $repo_path/.git ]]; then
		mkdir -p "$(dirname "$repo_path")"
		git clone --depth 1 --no-checkout "$remote" "$repo_path" >/dev/null
	fi
}

ensure_origin_remote() {
	local remote=$1
	local repo_path=$2
	local current_remote=""

	if current_remote=$(git -C "$repo_path" remote get-url origin 2>/dev/null); then
		if [[ $current_remote != "$remote" ]]; then
			git -C "$repo_path" remote set-url origin "$remote"
		fi
	else
		git -C "$repo_path" remote add origin "$remote"
	fi
}

update_default_branch_repo() {
	local repo_path=$1
	local default_branch=""
	local commit_sha=""

	git -C "$repo_path" fetch --depth 1 --prune origin '+refs/heads/*:refs/remotes/origin/*' >/dev/null
	git -C "$repo_path" remote set-head origin -a >/dev/null
	default_branch=$(git -C "$repo_path" symbolic-ref --short refs/remotes/origin/HEAD)
	default_branch=${default_branch#origin/}

	if [[ -z $default_branch ]]; then
		fail "failed to resolve default branch for $repo_path"
	fi

	git -C "$repo_path" checkout -B "$default_branch" "origin/$default_branch" >/dev/null 2>&1
	git -C "$repo_path" reset --hard "origin/$default_branch" >/dev/null
	git -C "$repo_path" clean -ffd >/dev/null
	commit_sha=$(git -C "$repo_path" rev-parse HEAD)

	printf '%s\n' "updated default branch ${default_branch} at ${commit_sha} -> ${repo_path}"
}

update_branch_repo() {
	local repo_path=$1
	local branch_name=$2
	local commit_sha=""

	git -C "$repo_path" fetch --depth 1 --prune origin "+refs/heads/${branch_name}:refs/remotes/origin/${branch_name}" >/dev/null
	git -C "$repo_path" checkout -B "$branch_name" "origin/$branch_name" >/dev/null 2>&1
	git -C "$repo_path" branch --set-upstream-to "origin/$branch_name" "$branch_name" >/dev/null 2>&1 || true
	git -C "$repo_path" reset --hard "origin/$branch_name" >/dev/null
	git -C "$repo_path" clean -ffd >/dev/null
	commit_sha=$(git -C "$repo_path" rev-parse HEAD)

	printf '%s\n' "updated branch ${branch_name} at ${commit_sha} -> ${repo_path}"
}

update_tag_repo() {
	local repo_path=$1
	local tag_selector=$2
	local resolved_tag=""
	local commit_sha=""

	git -C "$repo_path" fetch --force --tags origin >/dev/null

	if ! resolved_tag=$(resolve_highest_matching_tag "$tag_selector" "$repo_path"); then
		fail "no tags matched selector ${tag_selector} for ${repo_path}"
	fi

	git -C "$repo_path" checkout --detach "$resolved_tag" >/dev/null 2>&1
	git -C "$repo_path" reset --hard "$resolved_tag" >/dev/null
	git -C "$repo_path" clean -ffd >/dev/null
	commit_sha=$(git -C "$repo_path" rev-parse HEAD)

	printf '%s\n' "updated tag ${resolved_tag} (${tag_selector}) at ${commit_sha} -> ${repo_path}"
}

update_repo_from_entry() {
	local entry_json=$1
	local repo_path remote mode branch_name tag_selector

	repo_path=$(jq -r '.path' <<<"$entry_json")
	remote=$(jq -r '.remote' <<<"$entry_json")
	mode=$(jq -r '.mode' <<<"$entry_json")

	ensure_local_repository "$remote" "$repo_path"
	ensure_origin_remote "$remote" "$repo_path"

	case $mode in
		default_branch)
			update_default_branch_repo "$repo_path"
			;;
		branch)
			branch_name=$(jq -r '.branch' <<<"$entry_json")
			update_branch_repo "$repo_path" "$branch_name"
			;;
		tag)
			tag_selector=$(jq -r '.tag_selector' <<<"$entry_json")
			update_tag_repo "$repo_path" "$tag_selector"
			;;
		*)
			fail "unsupported repository mode: $mode"
			;;
	esac
}

update_all_managed_repositories() {
	local entry_json
	local failed=0
	local failures=()

	if ! manifest_exists_with_repositories; then
		echo "no managed repositories yet"
		return 0
	fi

	while IFS= read -r entry_json; do
		[[ -z $entry_json ]] && continue

		if ! (update_repo_from_entry "$entry_json"); then
			failed=1
			failures+=("$(jq -r '.id' <<<"$entry_json")")
		fi
	done < <(jq -c '.repositories[]' "$MANIFEST_PATH")

	if [[ $failed -ne 0 ]]; then
		echo "failed to update managed repositories:" >&2
		printf ' - %s\n' "${failures[@]}" >&2
		return 1
	fi

	return 0
}

list_managed_repositories() {
	if ! manifest_exists_with_repositories; then
		echo "no managed repositories yet"
		return 0
	fi

	jq -r '.repositories[] | "\(.id) \(.path)"' "$MANIFEST_PATH"
}

resolve_managed_repositories() {
	local query=$1
	local lowered_query=$1
	local exact_id_matches=""
	local exact_repo_matches=""
	local fuzzy_matches=""

	if [[ -z $query ]]; then
		fail "resolve query cannot be empty"
	fi

	if ! manifest_exists_with_repositories; then
		echo "no managed repositories yet"
		return 1
	fi

	lowered_query=$(printf '%s' "$query" | tr '[:upper:]' '[:lower:]')

	exact_id_matches=$(jq -r --arg query "$query" '
		.repositories[]
		| select(.id == $query)
		| "\(.id) \(.path)"
	' "$MANIFEST_PATH")

	if [[ -n $exact_id_matches ]]; then
		printf '%s\n' "$exact_id_matches"
		return 0
	fi

	exact_repo_matches=$(jq -r --arg query "$query" '
		.repositories[]
		| select(.repo == $query)
		| "\(.id) \(.path)"
	' "$MANIFEST_PATH")

	if [[ -n $exact_repo_matches ]]; then
		printf '%s\n' "$exact_repo_matches"
		return 0
	fi

	fuzzy_matches=$(jq -r --arg query "$lowered_query" '
		.repositories[]
		| select(
			(.id | ascii_downcase | contains($query))
			or (.owner | ascii_downcase | contains($query))
			or (.repo | ascii_downcase | contains($query))
			or (.path | ascii_downcase | contains($query))
		)
		| "\(.id) \(.path)"
	' "$MANIFEST_PATH")

	if [[ -n $fuzzy_matches ]]; then
		printf '%s\n' "$fuzzy_matches"
		return 0
	fi

	echo "no matches for: $query"
	return 1
}

main() {
	local manifest_entry=""

	require_dependencies

	if [[ ${1:-} == "--help" || ${1:-} == "-h" ]]; then
		usage
		exit 0
	fi

	if [[ ${1:-} == "list" ]]; then
		if [[ $# -ne 1 ]]; then
			usage >&2
			exit 1
		fi

		list_managed_repositories
		exit $?
	fi

	if [[ ${1:-} == "resolve" ]]; then
		if [[ $# -ne 2 ]]; then
			usage >&2
			exit 1
		fi

		resolve_managed_repositories "$2"
		exit $?
	fi

	if [[ $# -gt 1 ]]; then
		usage >&2
		exit 1
	fi

	if [[ $# -eq 0 ]]; then
		update_all_managed_repositories
		exit $?
	fi

	parse_ref_spec "$1"
	parse_repository_source "$REPOSITORY_SOURCE"
	manifest_entry=$(build_manifest_entry)

	update_repo_from_entry "$manifest_entry"
	manifest_upsert_repository "$manifest_entry"

	echo "$REPO_PATH"
}

main "$@"
