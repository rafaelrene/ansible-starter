{
  "$schema": "https://opencode.ai/config.json",
  "theme": "catppuccin",
  "autoupdate": false,
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "ctx7sk-5cb66bd3-9693-4b8a-9039-0f67fe13d359",
      },
      "enabled": true,
    },
    "gsmcp": {
      "type": "local",
      "command": [
        "/Users/rafael/.config/volta/bin/npx",
        "-y",
        "mcp-remote",
        "http://gs-mcp-server.orb.local/mcp",
        "--allow-http",
        "--header",
        "x-gs-mcp:true",
        "--header",
        "x-gs-mcp-token:929f3d34760c65bad695a193.281ea51a7162adb2101daa30910b4eb5e94e77d3c32d056f9cb2baf7a7827c94",
      ],
      "enabled": false,
    },
  },
}
