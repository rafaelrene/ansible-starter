{
  "$schema": "https://opencode.ai/config.json",
  "theme": "catppuccin",
  "autoupdate": false,
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "ctx7sk-5cb66bd3-9693-4b8a-9039-0f67fe13d359",
      },
      "enabled": true,
    },
    "gsmcp": {
      "type": "local",
      "command": [
        "/Users/rafael/.config/volta/bin/npx",
        "-y",
        "mcp-remote",
        "https://gs-mcp.dev.lab.groupsolver.com/mcp",
        "--allow-http",
        "--header",
        "x-gs-mcp:true",
        "--header",
        "gsauth:Dc36d3d28-f48b-43a2-a335-ccec9900d3a0",
      ],
      "enabled": false,
    },
  },
}
